# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_dev
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SYNC=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_TTL=604800

# Tokens
TTL_EXPIRATION=86400
INVITE_TOKEN_TTL=172800

# API Keys
API_KEY_PREFIX=sk_live_
API_KEY_EXPIRATION=300

# Throttling
THROTTLER_TTL=60000
THROTTLER_LIMIT=600
THROTTLER_AUTH_LIMIT=100

# App
NODE_ENV=development
URL_PATH=http://localhost:3000
ORIGIN=http://localhost:3000

# Email — Mailtrap (QA/dev, used when NODE_ENV != production)
MAILTRAP_API_KEY=your_mailtrap_api_key
MAILTRAP_TEST_INBOX_ID=your_mailtrap_inbox_id
MAILTRAP_FROM_EMAIL=noreply@yourdomain.com
MAILTRAP_FROM_NAME=Your App Name

# Email — AWS SES (production, used when NODE_ENV=production)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
